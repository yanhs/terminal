# Copy to .env and fill in.

# ── Dashboard login (start.sh / docker compose) ──────────────────────────────
# REQUIRED — the dashboard exposes live agent terminals, so it must have a password.
AGENTDECK_PASSWORD=change-me
AGENTDECK_USER=admin
# Docker: your domain → automatic HTTPS (point its DNS at the VPS first), or ":80" for http.
AGENTDECK_SITE=agents.example.com
AGENTDECK_EMAIL=you@example.com

# ── Telegram bridge (tg_bridge.py) — optional ────────────────────────────────
# Owner-only: the bridge ignores every chat except TG_BRIDGE_OWNER.
TG_BRIDGE_TOKEN=123456:your-bot-token-from-BotFather   # from @BotFather
TG_BRIDGE_OWNER=123456789                              # your numeric Telegram user id
# Where uploaded files / voice notes are stored + the public base URL they're served at:
TG_FILES_DIR=/path/to/uploads
TG_FILES_URL=https://example.com/files
# TG_WHISPER_PY=/path/to/venv/bin/python                # a python with faster-whisper (voice)
